{
  "name": "chronicles-of-infinity",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-build-info.js && vite",
    "build": "node scripts/generate-build-info.js && vite build",
    "preview": "vite preview",
    "format": "pnpm exec prettier --write .",
    "lint:i18n": "node scripts/lint-i18n.js",
    "lint": "pnpm lint:i18n",
    "test": "vitest run",
    "test:ui": "vitest run 'src/**/*.test.tsx'",
    "test:stable": "vitest run --exclude src/services/ai/agentic/__tests__/budgetUtils.test.ts --exclude src/services/ai/agentic/summary/summaryInitializer.test.ts",
    "test:cov": "vitest run --coverage.enabled true --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "test:cov:stable": "vitest run --coverage.enabled true --coverage.reportOnFailure true --coverage.reportsDirectory coverage --coverage.reporter=text-summary --coverage.reporter=json-summary --exclude src/services/ai/agentic/__tests__/budgetUtils.test.ts --exclude src/services/ai/agentic/summary/summaryInitializer.test.ts",
    "test:changed": "vitest related --run",
    "test:guardrails": "vitest run src/services/providers/__tests__/toolSchemaHint.test.ts src/services/providers/__tests__/allToolSchemaHints.test.ts src/services/providers/__tests__/providerSchemaGuardrails.test.ts src/services/prompts/__tests__/outlineToolInstructionConsistency.test.ts src/services/prompts/__tests__/toolCallingPromptGuardrails.test.ts src/services/ai/agentic/outline/__tests__/outlineTaskInstructionGuardrails.test.ts src/services/ai/__tests__/modelPromptMatching.test.ts src/services/vfs/__tests__/vfsSchemaGuardrails.test.ts",
    "prompts:deps:build": "tsx scripts/build-prompt-atom-graph.ts",
    "prompts:deps:check": "tsx scripts/build-prompt-atom-graph.ts --check",
    "prompts:loops:print": "node --import tsx scripts/print-loop-prompts.ts",
    "prompts:trace:check": "tsx scripts/check-atom-trace-style.ts",
    "skills:atoms:check": "tsx scripts/check-skill-target-atoms.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@electric-sql/pglite": "^0.3.14",
    "@google/genai": "^1.30.0",
    "@huggingface/transformers": "4.0.0-next.2",
    "@monaco-editor/react": "^4.7.0",
    "@openrouter/sdk": "^0.3.7",
    "@tailwindcss/vite": "^4.1.17",
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonrepair": "^3.13.1",
    "jszip": "^3.10.1",
    "mobile-drag-drop": "2.2.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.14.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.3.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.6",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@webgpu/types": "^0.1.66",
    "baseline-browser-mapping": "^2.9.19",
    "i18next-cli": "^1.42.6",
    "jsdom": "^28.0.0",
    "knip": "^5.73.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-toml": "^0.8.5",
    "vitest": "^4.0.18"
  }
}
