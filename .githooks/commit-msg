#!/usr/bin/env sh
set -eu

MSG_FILE="${1:-}"

if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  echo "[commit-msg] Missing commit message file."
  exit 1
fi

FIRST_LINE="$(head -n 1 "$MSG_FILE" | tr -d '\r')"

# Allow common auto-generated messages.
if echo "$FIRST_LINE" | grep -Eq '^(Merge( branch| pull request)|Revert ")'; then
  exit 0
fi

if echo "$FIRST_LINE" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'; then
  exit 0
fi

echo "[commit-msg] Invalid commit message."
echo "[commit-msg] Expected Conventional Commits, for example:"
echo "  feat(auth): add token refresh flow"
echo "  fix: handle null session response"
echo "  chore!: drop legacy settings schema"
echo
echo "[commit-msg] Your message:"
echo "  $FIRST_LINE"
exit 1
